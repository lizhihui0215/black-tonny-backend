APP_NAME=Black Tonny Backend
APP_ENV=production
APP_TIMEZONE=Asia/Shanghai
CAPTURE_DB_URL=mysql+pymysql://black_tonny:replace_me@127.0.0.1:3306/black_tonny_capture?charset=utf8mb4
SERVING_DB_URL=mysql+pymysql://black_tonny:replace_me@127.0.0.1:3306/black_tonny_serving?charset=utf8mb4
ADMIN_API_TOKEN=replace-me-with-strong-token
PAYLOAD_CACHE_DIR=/srv/black-tonny-backend/data/cache
SAMPLE_DATA_DIR=/srv/black-tonny-backend/data/sample
REBUILD_CRON=30 7 * * *
